<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#CC1a1a2e"
    android:minWidth="160dp">

    <!-- DRAG HANDLE — only this area moves the widget, buttons below are freely tappable -->
    <LinearLayout
        android:id="@+id/dragHandle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#CC0d1b2a"
        android:padding="8dp"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="👁 ObserverBot"
            android:textColor="#f0c040"
            android:textSize="11sp"
            android:textStyle="bold"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="drag here to move"
            android:textColor="#666666"
            android:textSize="9sp"/>

    </LinearLayout>

    <!-- Status text — informational, inside drag area -->
    <TextView
        android:id="@+id/statusText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Starting..."
        android:textColor="#cccccc"
        android:textSize="10sp"
        android:padding="8dp"
        android:background="#CC16213e"/>

    <!-- Export button — freely clickable, NOT part of drag handle -->
    <Button
        android:id="@+id/btnExport"
        android:layout_width="match_parent"
        android:layout_height="36dp"
        android:text="💾 EXPORT ZIP"
        android:textSize="11sp"
        android:textColor="#1a1a2e"
        android:backgroundTint="#f0c040"/>

</LinearLayout>
