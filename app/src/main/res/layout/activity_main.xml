<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32dp"
    android:background="#1a1a2e">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="👁 ObserverBot"
        android:textSize="28sp"
        android:textColor="#f0c040"
        android:textStyle="bold"
        android:layout_marginBottom="4dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Maximum Data Collector"
        android:textSize="13sp"
        android:textColor="#aaaaaa"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Tap START to begin"
        android:textSize="13sp"
        android:textColor="#90caf9"
        android:layout_marginBottom="32dp"/>

    <Button
        android:id="@+id/btnStart"
        android:layout_width="240dp"
        android:layout_height="52dp"
        android:text="▶ START OBSERVER"
        android:textSize="15sp"
        android:backgroundTint="#f0c040"
        android:textColor="#1a1a2e"
        android:layout_marginBottom="12dp"/>

    <Button
        android:id="@+id/btnAccessibility"
        android:layout_width="240dp"
        android:layout_height="52dp"
        android:text="♿ ACCESSIBILITY SETUP"
        android:textSize="13sp"
        android:backgroundTint="#3498db"
        android:textColor="#ffffff"
        android:layout_marginBottom="12dp"/>

    <Button
        android:id="@+id/btnStop"
        android:layout_width="240dp"
        android:layout_height="52dp"
        android:text="⛔ STOP OBSERVER"
        android:textSize="15sp"
        android:backgroundTint="#ff6b6b"
        android:textColor="#ffffff"/>

</LinearLayout>
