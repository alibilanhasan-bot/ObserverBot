<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/background"
        android:scaleType="centerCrop"
        android:contentDescription="background"/>

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#99000000"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="👁 ObserverBot"
            android:textSize="30sp"
            android:textColor="#f0c040"
            android:textStyle="bold"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Maximum Data Collector"
            android:textSize="13sp"
            android:textColor="#cccccc"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tap START to begin"
            android:textSize="13sp"
            android:textColor="#90caf9"
            android:layout_marginBottom="32dp"/>

        <Button
            android:id="@+id/btnStart"
            android:layout_width="240dp"
            android:layout_height="52dp"
            android:text="▶ START OBSERVER"
            android:textSize="15sp"
            android:backgroundTint="#f0c040"
            android:textColor="#1a1a2e"
            android:layout_marginBottom="12dp"/>

        <Button
            android:id="@+id/btnViewer"
            android:layout_width="240dp"
            android:layout_height="52dp"
            android:text="📊 VIEW DATA"
            android:textSize="15sp"
            android:backgroundTint="#9b59b6"
            android:textColor="#ffffff"
            android:layout_marginBottom="12dp"/>

        <Button
            android:id="@+id/btnAccessibility"
            android:layout_width="240dp"
            android:layout_height="52dp"
            android:text="♿ ACCESSIBILITY SETUP"
            android:textSize="13sp"
            android:backgroundTint="#3498db"
            android:textColor="#ffffff"
            android:layout_marginBottom="12dp"/>

        <Button
            android:id="@+id/btnStop"
            android:layout_width="240dp"
            android:layout_height="52dp"
            android:text="⛔ STOP OBSERVER"
            android:textSize="15sp"
            android:backgroundTint="#ff6b6b"
            android:textColor="#ffffff"/>

    </LinearLayout>

</RelativeLayout>
